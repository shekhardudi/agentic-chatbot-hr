# Copy to .env and fill in your values

# LLM provider: "anthropic" or "openai"
LLM_PROVIDER=anthropic

# Anthropic API
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI API (used when LLM_PROVIDER=openai)
OPENAI_API_KEY=sk-...

# PostgreSQL (matches docker-compose.yml)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=agentic_hr
POSTGRES_PASSWORD=agentic_hr_dev
POSTGRES_DB=agentic_hr

# NocoDB
NOCODB_URL=http://localhost:8080
NOCODB_API_TOKEN=

# Gitea
GITEA_URL=http://localhost:3000
GITEA_ADMIN_TOKEN=

# Mattermost
MATTERMOST_URL=http://localhost:8065
MATTERMOST_ADMIN_TOKEN=

# LLM model names
# Anthropic: claude-haiku-4-5-20251001 / claude-sonnet-4-6
# OpenAI:    gpt-4o-mini / gpt-4o
LLM_FAST_MODEL=claude-haiku-4-5-20251001
LLM_STRONG_MODEL=claude-sonnet-4-6

# Embedding
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384

# Backend
BACKEND_PORT=8000

# Guardrails: PII detection and prompt-injection safeguards
# Mode: "warn" (log only), "block_high_risk" (block SSN/card/bank_account), "strict" (block all PII)
GUARDRAIL_MODE=warn
# Comma-separated list of PII categories to detect: email, phone, ssn, credit_card, bank_account, date_of_birth, address
GUARDRAIL_ENABLED_PII_CATEGORIES=email,phone,ssn,credit_card,bank_account,date_of_birth,address
# Enable detection of prompt-injection attempts (true/false)
GUARDRAIL_DETECT_PROMPT_INJECTION=true
# Redact PII from audit logs when enabled (true/false)
GUARDRAIL_AUDIT_REDACT_PII=true
